# mk-pc-cpu-mem 설정 파일 예시
# 실제 운영 시 config.yaml 로 복사해 토큰/대상만 채우면 됩니다. 코드 수정 불필요.
#   cp config.yaml.example config.yaml
# 편집 후 적용:  systemctl restart pc-monitor   (또는 launchctl kickstart -k ...)

telegram:
  # @BotFather 에서 발급. 환경변수 PCMON_TELEGRAM_TOKEN 으로도 주입 가능(우선).
  token: "REPLACE_WITH_BOT_TOKEN"
  # 알림을 받을 chat id 목록. 본인 id 는 @userinfobot 으로 확인.
  chat_ids:
    - 0
  # 버튼/명령을 허용할 사용자 id (없으면 chat_ids 와 동일 취급). 권한 게이트.
  allowed_user_ids: []

thresholds:
  cpu_percent: 80          # CPU 사용률 임계값(%)
  ram_percent: 80          # RAM 사용률 임계값(%)

timing:
  check_interval_seconds: 30      # 상태 점검 주기
  alert_minutes: 5                # 임계값 초과 후 '주의' 알림까지 지속 시간
  restart_minutes: 20             # 초과 지속 시 '위험'(재시작 질문)까지
  response_timeout_minutes: 10    # 버튼 미응답 시 재질문까지 대기
  snooze_minutes: 10              # '무시' 선택 시 재질문까지 스누즈
  recovery_minutes: 1             # 임계값 이하로 이 시간 유지되면 '복구' 알림

watchdog:
  heartbeat_path: "/tmp/pcmon-heartbeat"   # monitor.py 가 매 주기 갱신하는 파일
  max_age_minutes: 5                       # 이 시간 이상 미갱신이면 '긴급' 알림
  allow_reboot: false                      # true 면 watchdog 가 재부팅 버튼 제공/실행 허용

control:
  allow_service_restart: true   # 텔레그램에서 서비스 재시작 허용
  allow_reboot: false           # 텔레그램에서 시스템 재부팅 허용(신중히)
  allow_run_command: false      # 원격 임의 명령 실행(브리지/ MCP). 기본 차단.
  command_allowlist: []         # allow_run_command=true 일 때 실행 허용 명령 prefix 목록

# ── 멀티호스트(권장): 한 모니터가 여러 대를 동시에 감시 ──────────────────────
# hosts 의 각 항목이 감시 대상 한 대. host="" 는 로컬(현재 PC), 아니면 SSH 별칭(원격).
#   system: true     → 그 PC 전체 CPU/RAM 을 단계별 감시
#   discovery: true  → 그 PC의 docker 컨테이너 + systemd 서비스를 exclude 빼고 자동 감시
#   targets: [...]   → 그 PC의 명시적 타겟(아래 type 참고)
# 원격 전제: `ssh <host>` 키 기반(비번 없이) 접속, 원격이 Linux/docker 그룹.
# 주의: 현재 PC가 꺼진 동안엔 감시 안 됨(24h 필요하면 대상 PC에 직접 설치 권장).
hosts:
  - { name: Mac,    host: "",        system: true }
  - { name: 미니PC, host: keymedi1, system: true, discovery: true }
  #   targets 예시:
  # - name: 워크스테이션
  #   host: keymedi1
  #   targets:
  #     - { name: open-design, type: docker, match: open-design }

# 발견 동작 옵션(호스트의 discovery:true 일 때 적용)
discovery:
  docker: true
  systemd: true
  refresh_minutes: 5    # 새 컨테이너/서비스 재발견 주기

# ── 단일 호스트(레거시): hosts 를 비우면 아래 remote/targets 로 동작 ───────────
# remote: { host: "" }            # 예: keymedi1 (현재 PC에서 그 PC만 감시)
# targets:                        # type: system | docker | systemd | launchd | process
#   - { name: 내 Mac, type: system, match: local }
#   - { name: open-design, type: docker, match: open-design }

# OS 기본 동작 서비스는 '시스템 경보' 의 원인 프로세스 집계에서 제외
exclude_services:
  - cron
  - ssh
  - sshd
  - dbus
  - NetworkManager
  - systemd
  - rsyslog
  - snapd
  - docker
  - dockerd
  - portainer
  - bluetooth
  - bluetoothd
  - cups
  - cupsd

system_alert:
  enabled: true            # 특정 서비스 외 전체 고부하 시 '시스템 경보'
  top_process_count: 5     # 원인 프로세스 상위 N개 표기
